# ============================================================
# Agentic E2E QE STLC Lifecycle - Environment Variables
# Copy this file to .env and fill in your values
# ============================================================

# --- LLM Configuration (Groq) ---
GROQ_API_KEY=your-groq-api-key-here
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_TEMPERATURE=0.1

# --- Jira Configuration ---
JIRA_URL=https://your-domain.atlassian.net
JIRA_USERNAME=your-email@example.com
JIRA_API_TOKEN=your-jira-api-token
JIRA_PROJECT_KEY=YOUR_PROJECT
JIRA_JQL_FILTER=issuetype = Story AND status = "To Do"

# --- GitHub Configuration ---
GITHUB_PERSONAL_ACCESS_TOKEN=your-github-pat
GITHUB_TARGET_REPO=chetangpande-ai/HdfcBank-Test-Automation
GITHUB_REFERENCE_REPO=chetangpande-ai/PW-Automation-Framework
GITHUB_TARGET_BRANCH=main

# --- Target Application (for Playwright MCP crawling) ---
TARGET_APP_URL=https://your-application-url.com

# --- Vector Store ---
CHROMA_PERSIST_DIR=./chroma_db
EMBEDDING_MODEL=sentence-transformers/all-mpnet-base-v2

# --- Logging ---
LOG_LEVEL=INFO
